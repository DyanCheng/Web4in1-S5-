# Supabase (shared)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Backend API (frontend)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Backend Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
# Required for Realtime chat tokens + admin user sync (Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: not used by Realtime chat (tokens come from Supabase Auth, not custom JWT signing)
SUPABASE_JWT_SECRET=
JWT_EXPIRES_IN=60

# Optional: direct PostgreSQL connection (overrides Supabase REST if set)
# SUPABASE_DB_CONNECTION_STRING=Host=...;Port=5432;Database=postgres;Username=...;Password=...;SSL Mode=Require

# Optional: enable [Dev] simulate payment button on deployed backend (demo/staging only)
ALLOW_PAYMENT_SIMULATION=true

# Google OAuth (Web Client ID from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# SePay Payment (bank transfer QR)
SEPAY_BANK_ACCOUNT=your-bank-account-number
SEPAY_BANK_NAME=Vietcombank
SEPAY_PAYMENT_CODE_PREFIX=CMCTOUR
SEPAY_WEBHOOK_API_KEY=
NEXT_PUBLIC_SEPAY_BANK_ACCOUNT=your-bank-account-number
NEXT_PUBLIC_SEPAY_BANK_NAME=Vietcombank
SEPAY_WEBHOOK_PUBLIC_URL=https://your-subdomain.ngrok-free.dev
NEXT_PUBLIC_SEPAY_WEBHOOK_URL=https://your-subdomain.ngrok-free.dev
